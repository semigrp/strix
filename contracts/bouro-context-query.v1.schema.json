{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semigrp.dev/ouro/contracts/bouro-context-query.v1.schema.json",
  "title": "Vendored Bouro ContextQueryV1",
  "type": "object",
  "required": ["schema", "roots", "purpose"],
  "properties": {
    "schema": { "const": "bouro.context-query/v1" },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "resource-ref.v1.schema.json" }
    },
    "purpose": { "type": "string", "minLength": 1 },
    "asOf": { "type": "string", "format": "date-time" },
    "tokenBudget": { "type": "integer", "minimum": 1 },
    "maxResources": { "type": "integer", "minimum": 1 },
    "includeKinds": {
      "type": "array",
      "items": {
        "enum": ["concept", "claim", "question", "hypothesis", "experiment", "procedure", "evidence", "assertion", "decision"]
      }
    },
    "allowedSensitivities": {
      "type": "array",
      "items": { "enum": ["public", "internal", "restricted"] }
    }
  },
  "additionalProperties": false
}
