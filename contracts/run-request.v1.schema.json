{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semigrp.dev/ouro/contracts/run-request.v1.schema.json",
  "title": "Ouro RunRequestV1",
  "type": "object",
  "required": ["schema", "work", "contextQuery", "procedure", "workspace"],
  "properties": {
    "schema": { "const": "ouro.run-request/v1" },
    "work": {
      "type": "object",
      "required": ["source", "title"],
      "properties": {
        "source": { "$ref": "resource-ref.v1.schema.json" },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["open", "closed"] }
      },
      "additionalProperties": false
    },
    "planTitle": { "type": "string", "minLength": 1 },
    "taskTitle": { "type": "string", "minLength": 1 },
    "experiment": {
      "allOf": [
        { "$ref": "resource-ref.v1.schema.json" },
        { "type": "object", "required": ["version"] }
      ]
    },
    "contextQuery": { "$ref": "bouro-context-query.v1.schema.json" },
    "procedure": {
      "type": "object",
      "required": ["artifact", "runtime", "inputs", "permissionTier"],
      "properties": {
        "definition": {
          "allOf": [
            { "$ref": "resource-ref.v1.schema.json" },
            { "type": "object", "required": ["version"] }
          ]
        },
        "artifact": {
          "allOf": [
            { "$ref": "resource-ref.v1.schema.json" },
            { "type": "object", "required": ["version", "digest", "uri"] }
          ]
        },
        "runtime": { "enum": ["node", "direct"] },
        "args": { "type": "array", "items": { "type": "string" } },
        "inputs": { "type": "object" },
        "permissionTier": { "enum": ["inspect", "workspace-write", "external-write"] },
        "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 86400000 },
        "retries": { "type": "integer", "minimum": 0, "maximum": 10 },
        "environment": {
          "type": "object",
          "properties": {
            "inherit": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" }
            },
            "set": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "workspace": {
      "type": "object",
      "required": ["ref", "path"],
      "properties": {
        "ref": {
          "allOf": [
            { "$ref": "resource-ref.v1.schema.json" },
            { "type": "object", "required": ["version"] }
          ]
        },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "expected"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "const": "exit_code" },
          "expected": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "object",
      "required": ["title", "observation"],
      "properties": {
        "when": { "enum": ["success", "always"] },
        "title": { "type": "string", "minLength": 1 },
        "observation": { "type": "string", "minLength": 1 },
        "assessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim", "stance", "rationale"],
            "properties": {
              "claim": {
                "allOf": [
                  { "$ref": "resource-ref.v1.schema.json" },
                  { "type": "object", "required": ["version"] }
                ]
              },
              "stance": { "enum": ["supports", "contradicts", "inconclusive"] },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
