{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semigrp.dev/ouro/contracts/bouro-register-evidence.v1.schema.json",
  "title": "Vendored Bouro RegisterEvidenceCommandV1",
  "type": "object",
  "required": ["schema", "source", "sourceEventId", "evidence"],
  "properties": {
    "schema": { "const": "bouro.register-evidence/v1" },
    "source": { "type": "string", "minLength": 1 },
    "sourceEventId": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "object",
      "required": ["title", "observation"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "observation": { "type": "string", "minLength": 1 },
        "observedAt": { "type": "string", "format": "date-time" },
        "sensitivity": { "enum": ["public", "internal", "restricted"] },
        "generatedBy": { "$ref": "resource-ref.v1.schema.json" },
        "derivedFrom": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "resource-ref.v1.schema.json" }
        },
        "attributedTo": {
          "type": "array",
          "items": { "$ref": "resource-ref.v1.schema.json" }
        },
        "assessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim", "stance", "rationale"],
            "properties": {
              "claim": { "$ref": "resource-ref.v1.schema.json" },
              "stance": { "enum": ["supports", "contradicts", "inconclusive"] },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "anyOf": [
        {
          "properties": { "generatedBy": true },
          "required": ["generatedBy"]
        },
        {
          "properties": { "derivedFrom": true },
          "required": ["derivedFrom"]
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
